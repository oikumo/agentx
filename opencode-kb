#!/bin/bash
# Opencode KB-First Wrapper
# This script forces opencode to query the Knowledge Base FIRST before any code search

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Extract user query
USER_QUERY="$*"

if [ -z "$USER_QUERY" ]; then
    echo -e "${RED}Error: No query provided${NC}"
    echo "Usage: ./opencode-kb \"What is MainController?\""
    exit 1
fi

echo -e "${GREEN}✓ KB-First Mode Enabled${NC}"
echo -e "${YELLOW}Query: $USER_QUERY${NC}"
echo ""

# Step 1: Query KB first using Advanced RAG
echo -e "${GREEN}Step 1: Querying Knowledge Base (Advanced RAG)...${NC}"
KB_OUTPUT=$(python3 .meta/tools/meta-harness-knowledge-base/kb ask "$USER_QUERY" --top-k 3 2>&1)

echo "$KB_OUTPUT"
echo ""

# Step 2: Check if KB has relevant information
if echo "$KB_OUTPUT" | grep -q "Answer synthesized"; then
    echo -e "${GREEN}✓ KB returned synthesized answer${NC}"
    echo ""
    echo -e "${YELLOW}Step 2: Answer from Knowledge Base above${NC}"
    echo ""
    echo "Based on the Knowledge Base (Advanced RAG), here's the answer to: \"$USER_QUERY\""
    echo ""
    
    # Extract and show the summary
    echo "$KB_OUTPUT" | grep -A 100 "## Summary" | head -20
    
    echo ""
    echo "---"
    echo "Source: Knowledge Base - Agent X"
    echo "Confidence: See KB output above"
    
elif echo "$KB_OUTPUT" | grep -q "No relevant entries"; then
    echo -e "${YELLOW}⚠ KB has no information about this topic${NC}"
    echo ""
    echo "Proceeding with normal opencode search..."
    echo ""
    opencode run "$USER_QUERY"
else
    echo -e "${YELLOW}KB query completed, now running opencode for additional context...${NC}"
    echo ""
    opencode run "$USER_QUERY"
fi
