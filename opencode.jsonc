// THIS OPENCODE CONFIGURATION FILE IS JUST FOR REFERENCE PURPOSE
{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "primary",
      "model": "openrouter/openrouter/auto",
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "tools": {
        "write": false,
        "edit": false
      }
    }
  },
  "permission": {
    "edit": "allow",
     "bash": {
        "*": "ask",
        "git *": "allow",
        "npm *": "allow",
        "rm *": "deny",
        "grep *": "allow",
        "ls *": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "webfetch": "deny",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow"
  },
  "mcp": {
    "knowledge-base": {
      "type": "local",
      "command": ["uv", "run", ".meta.development_tools/mcp/meta-harness-knowledge-base/knowledge_base_server.py"],
      "enabled": true
    },
    "products": {
      "type": "local",
      "command": ["uv", "run", ".meta.development_tools/mcp/dummy_products_server/server.py"],
      "enabled": true
    }
  }
}
