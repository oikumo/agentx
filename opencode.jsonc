// THIS OPENCODE CONFIGURATION FILE IS JUST FOR REFERENCE PURPOSE
{
  "$schema": "https://opencode.ai/config.json",
"agent": {
      "build": {
        "prompt": "{file:./prompts/build.txt}"
      },
      "code-reviewer": {
        "description": "Reviews code for best practices and potential issues",
        "mode": "primary",
        "model": "openrouter/openrouter/auto",
        "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
        "tools": {
          "write": false,
          "edit": false
        }
      }
    },
  "permission": {
    "edit": "allow",
     "bash": {
        "*": "ask",
        "echo *": "allow",
        "git *": "allow",
        "npm *": "allow",
        "rm *": "allow",
        "grep *": "allow",
        "ls *": "allow",
        "python3 *": "allow",
        "python *": "deny",
        "wc *": "allow",
        "cd *": "allow",
        "ls -ls *": "allow",
        "mv *": "allow"
     },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "webfetch": "deny",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow"
  }
}
